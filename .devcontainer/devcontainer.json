{
    "name": "ESP-IDF Development",
    "image": "espressif/idf:v5.3",
    "runArgs": [
        "--privileged"
    ],
    "mounts": [
        "source=/dev,target=/dev,type=bind"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "espressif.esp-idf-extension",
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools"
            ],
            "settings": {
                "idf.espIdfPath": "/opt/esp/idf",
                "idf.toolsPath": "/opt/esp",
                "idf.pythonBinPath": "/opt/esp/python_env/idf5.3_py3.10_env/bin/python",
                "idf.gitPath": "/usr/bin/git",
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash",
                        "args": ["-l"]
                    }
                },
                "C_Cpp.default.compilerPath": "/opt/esp/tools/xtensa-esp-elf/*/xtensa-esp-elf/bin/xtensa-esp32s3-elf-gcc",
                "C_Cpp.default.includePath": [
                    "${workspaceFolder}/**",
                    "/opt/esp/idf/components/**",
                    "/opt/esp/tools/xtensa-esp-elf/*/xtensa-esp-elf/include/**"
                ]
            }
        }
    },
    "containerEnv": {
        "IDF_PATH": "/opt/esp/idf",
        "IDF_TOOLS_PATH": "/opt/esp"
    },
    "postCreateCommand": ". /opt/esp/idf/export.sh",
    "postStartCommand": ". /opt/esp/idf/export.sh",
    "forwardPorts": [],
    "remoteUser": "root"
}
