menu "LLSS e-Ink Client Configuration"

    config LLSS_SERVER_URL
        string "LLSS Server URL"
        default "https://eink.tutu.eng.br/api"
        help
            The base URL for the Low Level Screen Service API.

    config LLSS_WIFI_AP_SSID_PREFIX
        string "WiFi AP SSID Prefix"
        default "LLSS-"
        help
            Prefix for the WiFi Access Point SSID used during provisioning.

    config LLSS_DEFAULT_POLL_MS
        int "Default poll interval (ms)"
        default 5000
        range 1000 60000
        help
            Default interval between device state polls to the LLSS server.

    config LLSS_EPD_WIDTH
        int "EPD Width (pixels)"
        default 800
        help
            E-Paper display width in pixels.

    config LLSS_EPD_HEIGHT
        int "EPD Height (pixels)"
        default 480
        help
            E-Paper display height in pixels.

endmenu
