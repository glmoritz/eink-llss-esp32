{
    "version": 4,
    "configurations": [
        {
            "name": "ESP-IDF",
            "compilerPath": "/opt/esp/tools/xtensa-esp-elf/*/xtensa-esp-elf/bin/xtensa-esp32s3-elf-gcc",
            "compileCommands": "${workspaceFolder}/build/compile_commands.json",
            "includePath": [
                "${workspaceFolder}/**",
                "/opt/esp/idf/components/**",
                "${workspaceFolder}/build/config"
            ],
            "defines": [],
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64"
        }
    ]
}
